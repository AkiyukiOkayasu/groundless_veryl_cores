    // MOSIをMISOにループバック接続
    assign miso = mosi;

    inst dut: SpiMaster::<SpiMode::Mode2> #(
        DATA_WIDTH: 8 ,
        CLK_DIV   : 20,
    ) (
        clk              ,
        rst              ,
        start            ,
        tx_data          ,
        rx_data          ,
        busy             ,
        done             ,
        sclk   : sclk_out,
