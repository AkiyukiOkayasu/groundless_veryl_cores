/// SCLKアイドル極性検証テスト
#[test(test_spi_idle_polarity)]
module test_spi_idle_polarity {
    // SPI共通型をimport
    import spi_pkg::SpiMode;

    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen (
        clk  ,
    );

    var start         : logic   ;
    var tx_data       : logic<8>;
    var rx_data_mode0 : logic<8>;
    var rx_data_mode2 : logic<8>;
    var busy_mode0    : logic   ;
    var busy_mode2    : logic   ;
    var done_mode0    : logic   ;
    var done_mode2    : logic   ;
    var sclk_out_mode0: logic   ;
    var sclk_out_mode2: logic   ;
    var mosi_mode0    : logic   ;
    var mosi_mode2    : logic   ;
    var cs_n_mode0    : logic   ;
    var cs_n_mode2    : logic   ;

    inst dut_mode0: SpiMaster::<SpiMode::Mode0> #(
        DATA_WIDTH: 8 ,
        CLK_DIV   : 20,
    ) (
        clk                    ,
        rst                    ,
        start                  ,
        tx_data                ,
        rx_data: rx_data_mode0 ,
        busy   : busy_mode0    ,
        done   : done_mode0    ,
        sclk   : sclk_out_mode0,
        mosi   : mosi_mode0    ,
        miso   : mosi_mode0    ,
        cs_n   : cs_n_mode0    ,
    );

    inst dut_mode2: SpiMaster::<SpiMode::Mode2> #(
        DATA_WIDTH: 8 ,
        CLK_DIV   : 20,
    ) (
        clk                    ,
        rst                    ,
        start                  ,
        tx_data                ,
        rx_data: rx_data_mode2 ,
        busy   : busy_mode2    ,
        done   : done_mode2    ,
        sclk   : sclk_out_mode2,
        mosi   : mosi_mode2    ,
        miso   : mosi_mode2    ,
        cs_n   : cs_n_mode2    ,
    );

    initial {
        start      = 0;
        tx_data    = 0;
        rst.assert();
        clk.next  (5);
        // Mode 0/1: SCLK idle Low
        $assert(sclk_out_mode0 == 0, "Mode 0 SCLK idle should be Low");
        // Mode 2/3: SCLK idle High
        $assert(sclk_out_mode2 == 1, "Mode 2 SCLK idle should be High");
        $finish();
    }
}

/// 連続送信テスト
#[test(test_spi_consecutive_transfer)]
module test_spi_consecutive_transfer {
    // SPI共通型をimport
    import spi_pkg::SpiMode;

    inst clk: $tb::clock_gen;
    inst rst: $tb::reset_gen (
        clk  ,
    );

    var start   : logic   ;
    var tx_data : logic<8>;
    var rx_data : logic<8>;
    var busy    : logic   ;
    var done    : logic   ;
    var sclk_out: logic   ;
    var mosi    : logic   ;
    var miso    : logic   ; // ループバック用
    var cs_n    : logic   ;

    // MOSIをMISOにループバック接続
    assign miso = mosi;

    inst dut: SpiMaster::<SpiMode::Mode0> #(
        DATA_WIDTH: 8 ,
        CLK_DIV   : 20,
    ) (
        clk              ,
        rst              ,
        start            ,
        tx_data          ,
        rx_data          ,
        busy             ,
        done             ,
        sclk   : sclk_out,
        mosi             ,
        miso             ,
        cs_n             ,
    );

    initial {
        start      = 0;
        rst.assert();
        clk.next  (10);

        // 1回目の送信
        tx_data  = 8'hA5;
        start    = 1;
        clk.next(1);
        start    = 0;
        clk.next(500); // 十分な時間待機
        $assert (busy == 0, "1回目の転送が完了していない");
        $assert (rx_data == 8'hA5, "1回目のループバックデータ不一致");

        // 2回目の送信
        tx_data  = 8'h5A;
        start    = 1;
        clk.next(1);
        start    = 0;
        clk.next(500); // 十分な時間待機
        $assert (busy == 0, "2回目の転送が完了していない");
        $assert (rx_data == 8'h5A, "2回目のループバックデータ不一致");

        $finish();
    }
}
